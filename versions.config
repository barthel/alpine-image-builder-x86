# Alpine OS rootfs version to use
# Overridable via ALPINE_OS_VERSION env var.
# Defaults to "latest" (pulls from uwebarthel/alpine-os-rootfs:latest on Docker Hub).
# For tagged builds the CI sets this to the full version (e.g. "3.21.0").
ALPINE_OS_VERSION="${ALPINE_OS_VERSION:-latest}"

# Alpine version (full: major.minor.patch) — must match the rootfs build
ALPINE_VERSION="3.21.0"
